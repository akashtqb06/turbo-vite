# Copy this file to .env.local and fill in values for local dev

# Override the dev proxy target (default: https://smartgrants-dev1.kpmgspectrum.com)
# VITE_PROXY_TARGET=https://smartgrants-dev1.kpmgspectrum.com

# API base URL (leave empty to use the Vite proxy at /api)
VITE_API_URL=

# Log level: debug | info | warn | error
VITE_LOG_LEVEL=info
