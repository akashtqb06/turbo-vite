{
  "name": "with-tailwind",
  "private": true,
  "scripts": {
    "build":       "turbo run build",
    "dev":         "turbo run dev",
    "lint":        "turbo run lint",
    "check-types": "turbo run check-types",
    "test":        "turbo run test",
    "test:coverage": "turbo run coverage",
    "format":      "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare":     "husky",
    "create-app":  "bash scripts/create-app.sh",
    "analyze":     "ANALYZE=true turbo run build",
    "deps:check":  "npx -y npm-check-updates --workspaces --interactive",
    "clean":       "turbo run clean && find . -name 'node_modules' -not -path '*/.git/*' -prune -exec rm -rf {} + 2>/dev/null; true"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "turbo": "^2.8.20"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "apps/demo/src/**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  },
  "dependencies": {
    "lucide-react": "^1.7.0"
  }
}
